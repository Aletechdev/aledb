MYSQL_PASSWORD=ale
MYSQL_HOST=db
MYSQL_PORT=3306
ALE_DATA_ROOT_DIR=/var/www/ale_analytics_data/
GOOGLE_ANALYTICS_TAG=UA-111512162-1