# use mysql docker container --docker service name is db
DEBUG=1
PUBLIC=0
DJANGO_SETTINGS_MODULE=aleinfo.settings_public
DJANGO_SERVER_HOST=127.0.0.1

# SEQUENCING_URL=https://console.cloud.google.com/storage/browser/aledb-data/ale_analytics_data/
SEQUENCING_URL=/aledata/

MYSQL_DATABASE=ale-db
MYSQL_USER=ale
MYSQL_PASSWORD=ale
MYSQL_HOST=db
MYSQL_PORT=3306
ALE_DATA_ROOT_DIR=/var/www/ale_analytics_data/
GOOGLE_ANALYTICS_TAG=UA-111512162-1

EMAIL_HOST_USER=aledbsoftware@gmail.com
EMAIL_HOST_PASSWORD='ucsd system biology group'
REDIS_URL=redis://aledb-redis

DEFENDER_LOGIN_FAILURE_LIMIT_USERNAME=3
DEFENDER_LOGIN_FAILURE_LIMIT_IP=5
DEFENDER_COOLOFF_TIME=3600  # seconds
