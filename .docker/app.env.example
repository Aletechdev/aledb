# .docker/app.env.example
#
# Template for the env file that docker-compose loads into the aledb-web
# container. Copy this file to .docker/one.env (the path the prod compose
# expects) and fill in real values, then bring the stack up:
#
#   cp .docker/app.env.example .docker/one.env
#   # edit .docker/one.env with your values
#   sudo docker-compose -f docker-compose-prod-asgi-host-nginx.yml up -d --build
#
# Items marked REQUIRED have no fallback in source — Django or
# pipeline.config will raise KeyError at import if they are missing.
# Everything else has a sensible default in source.
#
# All real .docker/*.env files are gitignored; only this template is
# tracked, so committing your edits to .docker/one.env is not possible.

# --- Django ---
DJANGO_SETTINGS_MODULE=aleinfo.settings_public
DJANGO_SERVER_HOST=127.0.0.1
# REQUIRED — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# --- Primary database (Azure MySQL flexible-server in prod, or any MySQL-compatible) ---
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=
MYSQL_PORT=3306

# --- Azure Storage + Batch (powers the /pipeline UI) ---
# All REQUIRED by pipeline/config.py; aledb-web fails at import if any are
# unset. If you don't intend to use the Azure pipeline integration, you'll
# need to stub these or modify pipeline.config to make them optional.
AZURE_BATCH_ACCOUNT_NAME=
AZURE_BATCH_ACCOUNT_URL=
AZURE_BATCH_ACCOUNT_KEY=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_VIRTUAL_MACHINE_ID=

# --- Email / SMTP ---
# The historical Gmail SMTP path is currently dead — see
# docs/operations/email_subsystem_review.md. Today the only feature using
# SMTP is admin lockout notifications (accounts/defender_middleware.py).
# EMAIL_HOST_PASSWORD is REQUIRED by source even though SMTP doesn't work;
# set it to any non-empty placeholder until the email subsystem is rebuilt.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Redis ---
# Default value for the bundled redis service in docker-compose. For password
# auth use: redis://:<password>@<host>:<port>/<db>. See
# docs/operations/redis_auth_hardening.md for the hardening plan.
REDIS_URL=redis://aledb-redis

# --- Behaviour flags ---
DEBUG=0
PUBLIC=0
SEQUENCING_URL=/aledata/
ALE_DATA_ROOT_DIR=/data/aledata/
GOOGLE_ANALYTICS_TAG=

# --- Django-defender (login brute-force lockout) ---
DEFENDER_LOGIN_FAILURE_LIMIT_USERNAME=3
DEFENDER_LOGIN_FAILURE_LIMIT_IP=5
DEFENDER_COOLOFF_TIME=60

# --- Optional: secondary lab databases (UCSD / DTU internal) ---
# These power specific views that aggregate read-only data from collaborator
# machines. Leave unset if you don't have access — affected views will
# simply not show data from those sources.
# UCSD_MACHINE_ONE_DATABASE=
# UCSD_MACHINE_ONE_USER=
# UCSD_MACHINE_ONE_PASSWORD=
# UCSD_MACHINE_ONE_HOST=
# UCSD_MACHINE_ONE_MYSQL_PORT=
# UCSD_MACHINE_TWO_*=
# DTU_MACHINE_ONE_*= / DTU_MACHINE_TWO_*= / DTU_MACHINE_THREE_*=
