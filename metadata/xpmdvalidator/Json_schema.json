{
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "project": {
        "$id": "project",
        "type": "string",
        "pattern": ".*\\S.*"
      },
      "experiment/subproject": {
        "$id": "experiment/subproject",
        "type": "string",
        "pattern": ".*\\S.*"
      },
      "A": {
        "$id": "A",
        "type": "string",
        "pattern": "^\\d+$"
      },
      "F": {
        "$id": "F",
        "type": "string",
        "pattern": "^\\d+$"
      },
      "I": {
        "$id": "I",
        "type": "string",
        "pattern": "^\\d+$"
      },
      "R": {
        "$id": "R",
        "type": "string",
        "pattern": "^\\d+$"
      },
      "sample type": {
        "$id": "sample type",
        "type": "string",
        "enum": ["clonal", "population"]
      },
      "starting strain": {
        "$id": "starting strain",
        "type": "string",
        "pattern": ".*\\S.*"
      },
      "reference file name(s)": {
        "$id": "reference file name(s)",
        "type": "string",
        "pattern": "^([^\\s]*)$"
      },
      "reference file url(s)": {
        "$id": "reference file url(s)",
        "type": "string",
        "pattern": "^((?:http(s)?:\\/\\/)?[\\w.-]+(?:\\.[\\w\\.-]+)+[\\w\\-\\._~:/?#[\\]@!\\$&'\\(\\)\\*\\+;=.]+,?)+$"
      },
      "medium derived from": {
        "$id": "medium derived from",
        "type": "string",
        "pattern": ".*\\S.*"
      },
      "carbon source": {
        "$id": "carbon source",
        "type": "string",
        "pattern": "^(^$)|(.*)(?=\\\b|)\\(-?[0-9]\\d*(\\.\\d+)?.*\\)$"
      },
      "taxonomy id": {
        "$id": "taxonomy id",
        "type": "string",
        "pattern": ".*\\S.*"
      },
      "accession": {
        "$id": "accession",
        "type": "string",
        "pattern": ".*\\S.*"
      },
      "owner": {
        "$id": "owner",
        "type": "string",
        "pattern": ".*\\S.*"
      },
      "owner email": {
        "$id": "owner email",
        "type": "string",
        "pattern": ".*\\S.*"
      },
      "environmental conditions": {
        "$id": "run-date",
        "type": "string",
        "pattern": "^(({(.*:.*(,)?)*)*})*$"
      },
      "media components": {
        "$id": "run-date",
        "type": "string",
        "pattern": "^(({(.*:.*(,)?)*)*})*$"
      }
    },
    "required": [
      "project",
      "experiment/subproject",
      "A",
      "F",
      "I",
      "R",
      "sample type",
      "starting strain",
      "reference file name(s)",
      "reference file url(s)",
      "medium derived from",
      "carbon source",
      "taxonomy id",
      "accession",
      "owner",
      "owner email",
      "environmental conditions",
      "media components"
    ]
  }
}
